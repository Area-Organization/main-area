{
  "name": "@area/shared",
  "main": "index.ts",
  "scripts": {
    "generate": "bun run --env-file=../../.env prisma generate",
    "push": "bun run --env-file=../../.env prisma db push",
    "init_schema": "dotenv -e ../../.env -- prisma migrate dev",
    "studio": "dotenv -e ../../.env -- prisma studio",
    "seed": "dotenv -e ../../.env -- bun run prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^7.0.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.3",
    "dotenv-cli": "^11.0.0",
    "prisma": "^7.0.1"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  }
}
